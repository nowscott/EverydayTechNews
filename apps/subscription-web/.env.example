NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 如果已知 data source ID，可直接配置并跳过数据库发现步骤
# NOTION_DATA_SOURCE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 订阅确认链接
APP_BASE_URL=http://localhost:5173
SUBSCRIPTION_CONFIRMATION_SECRET=replace_with_a_long_random_secret

# SMTP 用于向新订阅者发送确认邮件
SENDING_ACCOUNT=sender@example.com
SENDING_PASSWORD=smtp_password
SERVER=smtp.example.com
SMTP_PORT=465
# 可选：订阅者确认后，同时向站长发送新订阅通知
NOTIFICATION_EMAIL=owner@example.com
